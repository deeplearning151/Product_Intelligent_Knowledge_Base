# Copy this file to .env and fill in local values. Do not commit .env.

# MinerU / model cache
MINERU_MODEL_SOURCE=modelscope
MODELSCOPE_OFFLINE=1
MODELSCOPE_CACHE=
HF_HOME=
MD_ROOT_DIR=./temp-files/

# LLM
LLM_DEFAULT_MODEL=qwen-flash
VL_MODEL=qwen3-vl-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_DEFAULT_TEMPERATURE=0.1

# Embedding
BGE_M3_PATH=
BGE_M3=BAAI/bge-m3
BGE_DEVICE=cuda:0
BGE_FP16=1
ITEM_NAME_DIAG=1

# Milvus
MILVUS_URL=
CHUNKS_COLLECTION=kb_chunks
ENTITY_NAME_COLLECTION=kb_graph_entity_names
ITEM_NAME_COLLECTION=kb_item_names
EMBEDDING_DIM=1536
MILVUS_METRIC_TYPE=COSINE
MILVUS_MIN_COSINE_SCORE=0.75

# Neo4j
NEO4J_URI=
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# MongoDB
MONGO_URL=
MONGO_DB_NAME=kb002

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=knowledge-base-files
MINIO_IMG_DIR=/upload-images
MINIO_SECURE=False

# Reranker
BGE_RERANKER_LARGE=
BGE_RERANKER_DEVICE=cuda:0
BGE_RERANKER_FP16=1

# MCP / MinerU APIs
MCP_DASHSCOPE_BASE_URL=
MCP_DASHSCOPE_BASE_URL_STREAMABLE=https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp
MINERU_API_TOKEN=
MINERU_BASE_URL=

# Logging
LOG_CONSOLE_ENABLE=True
LOG_CONSOLE_LEVEL=INFO
LOG_FILE_ENABLE=True
LOG_FILE_LEVEL=INFO
LOG_FILE_RETENTION=7 days
